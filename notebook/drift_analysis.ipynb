from evidently.report import Report
from evidently.metric_preset import DataDriftPreset
import pandas as pd
from elasticsearch import Elasticsearch
import time

es = Elasticsearch("http://localhost:9200")

reference = pd.read_csv("reference_data.csv")
current = pd.read_json("prediction_logs.json", lines=True)

report = Report(metrics=[DataDriftPreset()])

report.run(
    reference_data=reference,
    current_data=current
)

result = report.as_dict()

drift_score = result["metrics"][0]["result"]["dataset_drift"]
drift_share = result["metrics"][0]["result"]["share_of_drifted_columns"]

doc = {
    "timestamp": time.time(),
    "dataset_drift": drift_score,
    "drifted_features_share": drift_share
}

es.index(
    index="mlops_drift_metrics",
    document=doc
)